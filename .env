# Local development - PostgreSQL
# For local dev, you can use: netlify dev (which provides a local Postgres)
# Or set your own PostgreSQL connection string below:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wifimurahbandung?schema=public"

# On Netlify, DATABASE_URL is automatically set when you add Netlify Database to your site
# No need to configure it manually in the Netlify dashboard - it's auto-provisioned
