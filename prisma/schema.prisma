generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())

  @@map("users")
}

model Provider {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  description String?
  website     String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leads Lead[]

  @@map("providers")
}

model Lead {
  id         String    @id @default(cuid())
  name       String
  whatsapp   String
  address    String?
  location   String?
  needType   String?
  budget     String?
  providerId String?
  source     String?
  status     String    @default("new")
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  provider Provider? @relation(fields: [providerId], references: [id])

  @@map("leads")
}

model Article {
  id            String          @id @default(cuid())
  title         String
  slug          String          @unique
  content       String
  excerpt       String?
  featuredImage String?
  categoryId    String?
  metaTitle     String?
  metaDesc      String?
  focusKeyword  String?
  published     Boolean         @default(false)
  views         Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  category ArticleCategory? @relation(fields: [categoryId], references: [id])

  @@map("articles")
}

model ArticleCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  articles Article[]

  @@map("article_categories")
}

model TrustIndicator {
  id       String  @id @default(cuid())
  icon     String
  value    String
  label    String
  isActive Boolean @default(true)
  order    Int     @default(0)

  @@map("trust_indicators")
}

model Keunggulan {
  id       String  @id @default(cuid())
  icon     String
  title    String
  desc     String? @map("description")
  isActive Boolean @default(true)
  order    Int     @default(0)

  @@map("keunggulan")
}

model Testimonial {
  id       String  @id @default(cuid())
  name     String
  location String?
  review   String
  photo    String?
  rating   Int     @default(5)
  isActive Boolean @default(true)
  order    Int     @default(0)

  @@map("testimonials")
}

model Faq {
  id       String  @id @default(cuid())
  question String
  answer   String
  isActive Boolean @default(true)
  order    Int     @default(0)

  @@map("faqs")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  group String?

  @@map("settings")
}

model SeoSetting {
  id            String  @id @default(cuid())
  page          String  @unique
  metaTitle     String?
  metaDesc      String?
  focusKeyword  String?
  ogImage       String?
  canonicalUrl  String?

  @@map("seo_settings")
}

model Popup {
  id        String   @id @default(cuid())
  type      String   @default("delay")
  title     String
  subtitle  String?
  ctaText   String?
  ctaUrl    String?
  isActive  Boolean  @default(true)
  delay     Int      @default(5)
  scrollPos Int      @default(50)
  showOnce  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("popups")
}

model Notification {
  id        String   @id @default(cuid())
  name      String
  location  String
  action    String
  timeAgo   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model TrackingScript {
  id       String  @id @default(cuid())
  name     String
  script   String
  isActive Boolean @default(true)
  position String  @default("head")

  @@map("tracking_scripts")
}
