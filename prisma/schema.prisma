generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id            String   @id @default(cuid())
  name          String
  whatsapp      String
  address       String?
  location      String?
  needType      String?  // rumah, kantor, gaming, cctv, usaha
  budget        String?
  providerId    String?
  status        String   @default("new") // new, contacted, pending, deal, cancel
  source        String?  // hero_form, main_form, popup, wa
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  provider      Provider? @relation(fields: [providerId], references: [id])
}

model Provider {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  description String?
  website     String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leads       Lead[]
}

model Article {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  content       String
  excerpt       String?
  featuredImage String?
  categoryId    String?
  metaTitle     String?
  metaDesc      String?
  focusKeyword  String?
  published     Boolean  @default(false)
  views         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category      ArticleCategory? @relation(fields: [categoryId], references: [id])
}

model ArticleCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  articles    Article[]
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  location  String?
  review    String
  photo     String?
  rating    Int      @default(5)
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  group String @default("general")
}

model SeoSetting {
  id            String  @id @default(cuid())
  page          String  @unique
  metaTitle     String?
  metaDesc      String?
  focusKeyword  String?
  ogImage       String?
  canonicalUrl  String?
}

model TrackingScript {
  id     String  @id @default(cuid())
  name   String
  script String
  isActive Boolean @default(true)
  position String @default("head") // head, body
}

model Popup {
  id          String   @id @default(cuid())
  type        String   @default("delay") // delay, exit_intent, scroll
  title       String
  subtitle    String?
  ctaText     String?
  ctaUrl      String?
  isActive    Boolean  @default(true)
  delay       Int      @default(5) // seconds
  scrollPos   Int      @default(50) // percentage
  showOnce    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  name      String
  location  String
  action    String
  timeAgo   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrustIndicator {
  id        String   @id @default(cuid())
  icon      String
  value     String
  label     String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Keunggulan {
  id        String   @id @default(cuid())
  icon      String
  title     String
  desc      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
